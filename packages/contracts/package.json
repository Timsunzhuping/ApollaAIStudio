{
  "name": "@apolla/contracts",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Single source of truth: shared types + JSON Schemas for the Apolla harness.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.5"
  }
}
