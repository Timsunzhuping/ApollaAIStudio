# Optional production TLS via Caddy (S-ops). Terminates HTTPS with an automatic Let's Encrypt
# certificate for a real hostname and reverse-proxies to the Apolla BFF. Use a hostname that resolves
# to this box — a registered domain, or a wildcard-DNS host like 47-76-168-50.sslip.io for IP-only
# boxes. Caddy uses the TLS-ALPN-01 challenge on :443, so it does not need :80 free.
#
# Recommended: run on the host network so Caddy reaches the BFF over loopback (works even when a host
# firewall blocks the docker bridge → host), and move Caddy's HTTP port off :80 so it never collides
# with an unrelated service that owns :80 on a shared box:
#
#   docker run -d --name apolla-caddy --restart unless-stopped --network host \
#     -e APOLLA_HOSTNAME=47-76-168-50.sslip.io -e APOLLA_UPSTREAM=127.0.0.1:8080 \
#     -v /opt/apolla/infra/Caddyfile:/etc/caddy/Caddyfile:ro \
#     -v apolla_caddy_data:/data caddy:2
#
# Bridge-network alternative (needs the docker bridge → host path open):
#   docker run -d --name apolla-caddy --restart unless-stopped -p 443:443 \
#     -e APOLLA_HOSTNAME=... -e APOLLA_UPSTREAM=host.docker.internal:8080 \
#     --add-host host.docker.internal:host-gateway -v .../Caddyfile:/etc/caddy/Caddyfile:ro \
#     -v apolla_caddy_data:/data caddy:2

{
	# Move the ACME/redirect HTTP listener off :80 and don't bind :80 for redirects — TLS-ALPN-01 on
	# :443 is enough, and :80 may belong to another service on a shared host.
	http_port 8081
	auto_https disable_redirects
}

{$APOLLA_HOSTNAME:47-76-168-50.sslip.io} {
	encode zstd gzip
	reverse_proxy {$APOLLA_UPSTREAM:127.0.0.1:8080} {
		flush_interval -1
		header_up X-Forwarded-Proto https
	}
	request_body {
		max_size 16MB
	}
}
