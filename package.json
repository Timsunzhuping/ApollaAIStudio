{
  "name": "apolla",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "dev": "pnpm --filter @apolla/bff dev",
    "eval": "pnpm --filter @apolla/evals eval",
    "contract-test": "vitest run contract"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "eslint": "^9.15.0",
    "prettier": "^3.4.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.16.0",
    "vitest": "^2.1.8"
  }
}
